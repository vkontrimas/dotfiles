# local-llm/llama environment overrides
#
#   cp .env.example .env
#   $EDITOR .env
#
# Most settings are hardcoded directly in compose/bonsai.yml — this is a
# single-machine dotfiles checkout, not a shared template. Only rare knobs
# live here.

# Context window. Default is 262144 (the model's full trained context).
# That's a tight fit on a single 24GB 3090 once weights + 4-bit KV are
# accounted for — lower this (e.g. 131072) if you see OOM at boot.
# CTX_SIZE=262144

# HuggingFace token — only needed if prism-ml/Ternary-Bonsai-27B-gguf ever
# requires gated access to download. Not needed for the manual download step
# described below as of writing.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Model weights are not fetched automatically (multi-GB download). Download
# once, manually, before first `docker compose up`:
#
#   huggingface-cli download prism-ml/Ternary-Bonsai-27B-gguf \
#     Ternary-Bonsai-27B-Q2_0.gguf \
#     --local-dir /home/kinetic/data/llm-models/bonsai
#
# 7.17 GB — the group-size-128 ternary format the PrismML-Eng fork expects
# (not Q2_g64, which is mainline's group-size-64 variant).
# ---------------------------------------------------------------------------
