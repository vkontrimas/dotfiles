# local-llm/vllm environment overrides
#
#   cp .env.example .env
#   $EDITOR .env
#
# Most settings (model dir, cache dir, port, GPU memory utilization, max
# context, restart policy) are hardcoded directly in compose/dual.yml and
# compose/solo.yml — this is a single-machine dotfiles checkout, not a
# shared template, so there's no need to indirect through env vars for
# values that never change. Only the HF token (a secret, must never be
# committed) and a few rare debug knobs are read from here.

# HuggingFace token — only needed for gated/private repos. The AutoRound
# INT4 weights used here are public, so this can usually be left blank.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# PyTorch CUDA allocator config. If the engine crashes at boot inside
# gptq_marlin_repack with "CUDA driver error: device not ready", try
# expandable_segments:False.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:False

# Disable CUDA graph capture (costs ~20-30% TPS, avoids graph-capture OOM).
# VLLM_ENFORCE_EAGER=1

# KV cache quantization (fp8_e5m2 default — 8-bit, good quality/headroom
# balance on a 3090).
# KV_CACHE_DTYPE=fp8_e5m2

# Sampling defaults (per-request OpenAI API fields still override these).
# TEMP=0.6
# TOP_P=0.95
# TOP_K=20
# MIN_P=0.0
# REPEAT_PENALTY=1.0

# Pin a specific vLLM image instead of the default v0.22.0.
# VLLM_IMAGE=vllm/vllm-openai:v0.22.0
