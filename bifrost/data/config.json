{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "vllm": {
      "keys": [
        {
          "name": "vllm-local",
          "value": "",
          "models": ["qwen3.6-27b-autoround"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "http://host.docker.internal:11434",
            "model_name": "qwen3.6-27b-autoround"
          }
        }
      ],
      "network_config": {
        "allow_private_network": true
      }
    }
  },
  "governance": {
    "pricing_overrides": [
      {
        "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "name": "Local vLLM electricity cost",
        "scope_kind": "provider",
        "provider_id": "vllm",
        "match_type": "exact",
        "pattern": "qwen3.6-27b-autoround",
        "request_types": ["chat_completion"],
        "pricing_patch": "{\"input_cost_per_token\":0.0000007,\"output_cost_per_token\":0.0000007}"
      }
    ]
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./logs.db"
    }
  }
}
