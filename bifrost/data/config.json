{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "vllm": {
      "keys": [
        {
          "name": "vllm-local",
          "value": "",
          "models": ["qwen3.6-27b-autoround"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "http://host.docker.internal:11434",
            "model_name": "qwen3.6-27b-autoround"
          }
        },
        {
          "name": "bonsai-local",
          "value": "",
          "models": ["bonsai-ternary-27b"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "http://host.docker.internal:11434",
            "model_name": "bonsai-ternary-27b"
          }
        }
      ],
      "network_config": {
        "allow_private_network": true,
        "stream_idle_timeout_in_seconds": 300
      }
    }
  },
 
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./logs.db"
    }
  }
}
