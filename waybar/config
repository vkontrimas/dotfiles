{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces"],
  "modules-right": [
    "custom/ram-label",
    "custom/ram-memory",
    "custom/gpu-sep",
    "custom/gpu-label",
    "custom/gpu-memory",
    "custom/llm-sep",
    "custom/llm-label",
    "custom/llm-status",
    "custom/llm-status-err",
    "custom/llm-dual",
    "custom/llm-solo",
    "custom/llm-sep2",
    "custom/pwr-label",
    "custom/pwr-toggle",
    "custom/pwr-sep",
    "clock",
    "tray"
  ],
  "custom/gpu-label": {
    "format": "GPU"
  },
  "custom/gpu-memory": {
    "exec": "$HOME/.config/waybar/scripts/gpu-memory.sh",
    "interval": 5
  },
  "custom/gpu-sep": {
    "format": "|"
  },
  "custom/ram-label": {
    "format": "RAM"
  },
  "custom/ram-memory": {
    "exec": "$HOME/.config/waybar/scripts/ram-memory.sh",
    "interval": 5
  },
  "custom/llm-sep": {
    "format": "|"
  },
  "custom/llm-label": {
    "format": "LLM"
  },
  "custom/llm-status": {
    "exec": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py health",
    "interval": 10
  },
  "custom/llm-status-err": {
    "exec": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py health-err",
    "interval": 10,
    "return-type": "json",
    "format": "{}"
  },
  "custom/llm-dual": {
    "exec": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py button vllm/dual DUAL",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py toggle vllm/dual"
  },
  "custom/llm-solo": {
    "exec": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py button llamacpp/mtp SOLO",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py toggle llamacpp/mtp"
  },
  "custom/llm-sep2": {
    "format": "|"
  },
  "custom/pwr-label": {
    "format": "PWR"
  },
  "custom/pwr-toggle": {
    "exec": "$HOME/.config/waybar/scripts/power-profile.sh button",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/scripts/power-profile.sh toggle"
  },
  "custom/pwr-sep": {
    "format": "|"
  },
  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },
  "tray": {
    "spacing": 8
  }
}
