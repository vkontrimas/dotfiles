{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces"],
  "modules-right": [
    "custom/ram-label",
    "custom/ram-memory",
    "custom/sep",
    "custom/gpu-label",
    "custom/gpu-memory",
    "custom/sep",
    "custom/mov-label",
    "custom/mov-status",
    "custom/sep",
    "custom/pwr-label",
    "custom/pwr-toggle",
    "custom/sep",
    "custom/dsp-label",
    "custom/dsp-timeout",
    "custom/sep",
    "custom/sus-label",
    "custom/sus-inhibit",
    "custom/sep",
    "clock",
    "tray"
  ],
  "custom/gpu-label": {
    "format": "GPU"
  },
  "custom/gpu-memory": {
    "exec": "$HOME/.config/waybar/scripts/gpu-memory.sh",
    "interval": 5
  },
  "custom/sep": {
    "format": "|"
  },
  "custom/ram-label": {
    "format": "RAM"
  },
  "custom/ram-memory": {
    "exec": "$HOME/.config/waybar/scripts/ram-memory.sh",
    "interval": 5
  },

  "custom/pwr-label": {
    "format": "PWR"
  },
  "custom/pwr-toggle": {
    "exec": "$HOME/.config/waybar/scripts/power-profile.sh button",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/scripts/power-profile.sh toggle"
  },

  "custom/dsp-label": {
    "format": "DSP"
  },
  "custom/dsp-timeout": {
    "exec": "$HOME/.config/waybar/scripts/display-timeout.sh button",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/scripts/display-timeout.sh toggle"
  },

  "custom/sus-label": {
    "format": "SUS"
  },
  "custom/sus-inhibit": {
    "exec": "$HOME/.config/waybar/scripts/suspend-inhibit.sh button",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/scripts/suspend-inhibit.sh toggle"
  },

  "custom/mov-label": {
    "format": "MOV"
  },
  "custom/mov-status": {
    "exec": "$HOME/.config/waybar/scripts/emby-server.sh button",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "$HOME/.config/waybar/scripts/emby-server.sh toggle"
  },

  "clock": {
    "format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },
  "tray": {
    "spacing": 8
  }
}
