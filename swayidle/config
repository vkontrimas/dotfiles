timeout 300 'swaylock -f'
timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
timeout 900 'systemctl suspend'
before-sleep '$HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py suspend; swaylock -f'
after-resume 'swaymsg "output * power on"; $HOME/.config/waybar/llm/.venv/bin/python $HOME/.config/waybar/llm/client.py wake'
