timeout 300 'swaylock -f'
timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
timeout 900 'systemctl suspend'
before-sleep 'echo suspend | socat - UNIX-CONNECT:$HOME/.cache/waybar-llm.sock; swaylock -f'
after-resume 'swaymsg "output * power on"; echo wake | socat - UNIX-CONNECT:$HOME/.cache/waybar-llm.sock'
